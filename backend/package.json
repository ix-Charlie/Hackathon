{
  "name": "horizon-backend",
  "version": "1.0.0",
  "description": "Document processing backend for Horizon with job queue support",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "sh start.sh",
    "worker": "tsx src/worker.ts",
    "worker:image": "tsx src/imageWorker.ts",
    "worker:extraction": "tsx src/extractionWorker.ts",
    "worker:prod": "node dist/worker.js",
    "worker:image:prod": "node dist/imageWorker.js",
    "worker:extraction:prod": "node dist/extractionWorker.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\" \"npm run worker:image\" \"npm run worker:extraction\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kenjiuno/msgreader": "^1.28.0",
    "@supabase/supabase-js": "^2.39.0",
    "bullmq": "^5.1.0",
    "canvas": "^3.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "html-to-text": "^9.0.5",
    "ioredis": "^5.3.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.6.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "openai": "^4.24.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.4.530",
    "pg": "^8.18.0",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "docx": "^9.1.1",
    "pdfkit": "^0.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/html-to-text": "^9.0.4",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/pdfkit": "^0.13.8",
    "concurrently": "^8.2.2",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
